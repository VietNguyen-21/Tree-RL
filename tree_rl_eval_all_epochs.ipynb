      "GPU: NVIDIA GeForce RTX 4060 Laptop GPU\n"
     ]
    }
   ],
   "source": [
    "# ============================================================\n",
    "# Cell 2: Imports and device\n",
    "# ============================================================\n",
    "import csv\n",
    "import os\n",
