    "# Cell 7: Display and pick best models\n",
    "# ============================================================\n",
    "try:\n",
    "    import pandas as pd\n",
    "    df = pd.read_csv(RESULTS_CSV)\n",
    "    display(df)\n",
    "    metric_cols = [c for c in df.columns if c.startswith('recall_')]\n",
    "    best_rows = []\n",
    "    for metric in metric_cols:\n",
    "        best = df.sort_values(metric, ascending=False).iloc[0].copy()\n",
    "        best['best_metric'] = metric\n",
    "        best['best_recall'] = best[metric]\n",
    "        best_rows.append(best)\n",
    "    print('Best row for each recall metric')\n",
    "    display(pd.DataFrame(best_rows)[['best_metric', 'best_recall', 'checkpoint', 'epoch', 'levels', 'proposals']])\n",
    "    print('Best by recall_all_0.5')\n",
